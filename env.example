APP_NAME=App-Dev

# ========================
# SERVER SETTINGS
# ========================
SERVER_ENV=development
SERVER_NAME=service-app-api
SERVER_URL=127.0.0.1:6001
SERVER_PORT=6001
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10
SERVER_IDLE_TIMEOUT=15
SERVICE_LANG=en

# ========================
# DATABASE SETTINGS (REQUIRED)
# ========================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=db_app
DB_NAME_TEST=db_app_test
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_TIMEOUT=10s
DB_DIAL_TIMEOUT=10s
DB_READ_TIMEOUT=10s
DB_WRITE_TIMEOUT=10s

# ========================
# REDIS SETTINGS (OPTIONAL — leave REDIS_HOST empty to disable)
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=8ms
REDIS_MAX_RETRY_BACKOFF=512ms
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_TIMEOUT=4s
REDIS_NAMESPACE=service-app
REDIS_EXPIRATION=10m

# ========================
# ASYNQ SETTINGS (requires Redis)
# ========================
ASYNQ_CONCURRENCY=10
